# ── LLM ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Model to use (default: gpt-4o-mini)
LLM_MODEL=gpt-4o-mini
# Retry attempts on transient LLM errors
LLM_MAX_RETRIES=3

# ── Exa.ai (social / news sentiment for the Bull) ───────────────────────────
EXA_API_KEY=exa-...
EXA_NUM_RESULTS=8

# ── Binance WebSocket (real-time price feed) ─────────────────────────────────
# Symbol in Binance stream format, e.g. btcusdt, ethusdt
WS_SYMBOL=btcusdt
# Seconds between snapshots delivered to the reasoning loop (min 0.1)
WS_THROTTLE_SECS=1.0

# ── Alpaca (paper / live order execution) ─────────────────────────────────────
# Set ALPACA_ENABLED=true to actually submit orders; default is false (simulation only)
ALPACA_ENABLED=false
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Paper trading endpoint (change to https://api.alpaca.markets for live)
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Risk parameters ──────────────────────────────────────────────────────────
# Minimum bull confidence to consider executing a trade  (0–1)
BULL_THRESHOLD=0.8
# Maximum bear confidence that still allows execution    (0–1)
BEAR_THRESHOLD=0.3
# Stop-loss percentage below entry price                  (e.g. 0.02 = 2 %)
STOP_LOSS_PCT=0.02

# ── Dashboard / API ───────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
# Optional: set a secret to require X-API-Token on /api/trigger
API_AUTH_TOKEN=
# Max requests per minute for /api/trigger (all callers combined)
API_RATE_LIMIT_RPM=30

# ── Resilience ────────────────────────────────────────────────────────────────
# Consecutive failures before a circuit breaker opens
CIRCUIT_BREAKER_THRESHOLD=5
# Seconds a circuit stays OPEN before attempting a recovery probe
CIRCUIT_BREAKER_TIMEOUT_SECS=60.0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Set to true for structured JSON log output (recommended for production)
LOG_JSON=false

# ── Memory ───────────────────────────────────────────────────────────────────
MEMORY_PATH=agent_memory.json
# Maximum lessons retained per agent (older lessons are pruned)
MEMORY_MAX_LESSONS=10
